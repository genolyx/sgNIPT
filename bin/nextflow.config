/*
 * ============================================================================
 *  Single Gene NIPT Pipeline - Nextflow Configuration
 * ============================================================================
 *
 *  Twist Custom Panel: UCL_SingleGeneNIPT_TE-96276661_hg38
 *  - Target regions: 5,138 regions, ~1.07 Mb, 183 genes, 22 chromosomes
 *  - Probe coverage: 99.46% (777,457 bp covered by probes)
 *  - Zero-probe regions: 29 (3,786 bp) - flagged in QC
 *  - No Y-chromosome targets → ChrX-based supplementary FF for male fetus
 * ============================================================================
 */

// ── Pipeline parameters ─────────────────────────────────────────────────────
params {

    // ── Pipeline metadata ───────────────────────────────────────────────
    pipeline_version = '1.1.0'

    // ── Input / Output ──────────────────────────────────────────────────
    input              = null       // Path to samplesheet CSV
    outdir             = './results'

    // ── Reference genome (hg38) ─────────────────────────────────────────
    reference_fasta    = null       // Path to hg38 reference FASTA
    bwa_index_dir      = null       // Directory containing BWA-MEM2 index files
    genome_prefix      = 'hg38'

    // ── Target BED files (Twist Custom Panel) ───────────────────────────
    //  All BED files are hg38-based from Twist design TE-96276661.
    //  Users place these in {DATA_DIR}/target_bed/ on the host.
    //
    //  target_bed:       All_target_regions_UCL_SingleGeneNIPT_TE-96276661_hg38_*.bed
    //                    → Primary BED for alignment extraction, variant calling, coverage QC
    //                    → 5,138 regions, ~1.07 Mb
    //
    //  probes_bed:       Probes_merged_ok_shareable_UCL_SingleGeneNIPT_TE-96276661_hg38_*.bed
    //                    → Actual probe footprint for capture efficiency QC
    //                    → 3,577 probe regions, ~780 kb
    //
    //  ff_snps_bed:      User-generated common SNP list within target regions
    //                    → For Fetal Fraction estimation (informative SNP method)
    //                    → Should contain common SNPs (MAF > 5%) from dbSNP/KRGDB
    //                    → Format: chrom, start, end, rsID, ref, alt, MAF
    //
    //  zero_probe_bed:   Target_regions_with_zero_probes_UCL_SingleGeneNIPT_TE-96276661_hg38_*.bed
    //                    → 29 regions (3,786 bp) with no probe coverage
    //                    → Used for QC warnings on uncovered pathogenic loci
    //
    //  gene_list:        singleGene_NIPT gene list (182 genes)
    //                    → TSV with gene names and disease info for report annotation
    //
    target_bed         = null       // [REQUIRED] All target regions BED
    probes_bed         = null       // [RECOMMENDED] Probe footprint BED for capture QC
    ff_snps_bed        = null       // [RECOMMENDED] Common SNP BED for FF estimation
    zero_probe_bed     = null       // [OPTIONAL] Zero-probe regions BED for QC warnings
    gene_list          = null       // [OPTIONAL] Gene list TSV for report annotation

    // ── Preprocessing (fastp) ───────────────────────────────────────────
    fastp_qualified_quality = 15
    fastp_min_length        = 36
    fastp_extra_args        = ''

    // ── Alignment (aligned with carrier-screening WES: bwa mem | samtools sort -m 768M) ──
    //  aligner: 'bwa' = BWA (uses .bwt index), 'bwa-mem2' = BWA-MEM2 (uses .bwt.2bit.64)
    aligner                 = 'bwa'   // 'bwa' or 'bwa-mem2'
    bwa_extra_args          = ''
    samtools_sort_mem       = '768M'  // per-thread sort memory (same as carrier-screening ALIGN_AND_SORT)
    min_mapping_quality     = 30
    min_base_quality        = 20
    // true = Picard MarkDuplicates (same algorithm as carrier-screening GATK MarkDuplicates)
    use_picard_markdup      = true

    // ── Fetal Fraction Estimation ───────────────────────────────────────
    //  Primary method: SNP-based informative SNP method
    //    - Uses ff_snps_bed (common SNPs within target regions)
    //    - Falls back to target_bed if ff_snps_bed not provided
    //  Supplementary methods:
    //    - ChrX-based (for male fetus; no Y-chr targets in this panel)
    //    - Fragment size distribution
    //
    ff_variant_caller       = 'bcftools'   // 'bcftools' or 'freebayes'
    ff_min_alt_fraction     = 0.005
    ff_min_alt_count        = 2
    ff_max_reads            = 10000000
    ff_config               = null         // Optional JSON config for fetal_fraction.py
    mpileup_max_depth       = 10000

    // ── Variant Calling ─────────────────────────────────────────────────
    //  'bcftools' = mpileup+call (default NIPT)
    //  'gatk'     = HaplotypeCaller + VariantFiltration (carrier-screening CALL_VARIANTS parity)
    //  'mutect2'  = Mutect2 + FilterMutectCalls (legacy somatic-style; rarely for germline)
    variant_caller          = 'bcftools'
    vc_min_alt_fraction     = 0.005
    vc_min_alt_count        = 2
    vc_min_depth            = 50

    // ── Variant Annotation ──────────────────────────────────────────────
    run_annotation          = false
    annotation_tool         = 'bcftools'   // 'bcftools' or 'snpsift'
    clinvar_vcf             = null
    annotation_db           = null

    // ── Variant Analysis ────────────────────────────────────────────────
    variant_analysis_config = null         // Optional JSON config for variant_analysis.py

    // ── QC Thresholds ───────────────────────────────────────────────────
    fastq_qc_thresholds    = null          // Optional JSON with custom FASTQ QC thresholds
    bam_qc_thresholds      = null          // Optional JSON with custom BAM QC thresholds

    // ── Docker-internal profile (when Nextflow runs inside container) ───
    container_cpus             = null      // Override via --container_cpus (default: 16)
    container_memory           = null      // Override via --container_memory (default: 32.GB)

    // ── Panel-specific QC thresholds (Twist TE-96276661) ────────────────
    //  These are tuned for the ~780 kb probe footprint with ~5,138 target regions
    min_on_target_rate         = 0.50      // Minimum on-target read fraction
    min_mean_target_coverage   = 500.0     // Minimum mean coverage across targets
    min_probe_coverage_rate    = 0.95      // Minimum fraction of probes with >= 100x
    max_zero_cov_targets       = 50        // Maximum targets with zero coverage
}


// ── Process resource defaults ───────────────────────────────────────────────
process {
    errorStrategy = 'retry'
    maxRetries    = 2

    withLabel: 'process_low' {
        cpus   = 1
        memory = '2.GB'
        time   = '1.h'
    }
    withLabel: 'process_medium' {
        cpus   = 4
        memory = '8.GB'
        time   = '4.h'
    }
    withLabel: 'process_high' {
        cpus   = 8
        memory = '16.GB'
        time   = '8.h'
    }
}


// ── Execution profiles ──────────────────────────────────────────────────────
profiles {

    standard {
        process.executor = 'local'
    }

    /*
     * docker_internal: Used when Nextflow runs INSIDE a Docker container
     * (i.e., the entrypoint.sh scenario). All tools are already installed
     * in the container, so no nested Docker is needed. Nextflow simply
     * runs processes locally within the container.
     */
    docker_internal {
        process.executor = 'local'

        // Limit total concurrent tasks within the container
        executor {
            queueSize   = 8
            cpus        = params.container_cpus   ?: 16
            memory      = params.container_memory ?: '32.GB'
        }
    }

    docker {
        docker.enabled = true
        docker.runOptions = '-u $(id -u):$(id -g)'
    }

    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
    }

    conda {
        conda.enabled = true
    }

    slurm {
        process.executor = 'slurm'
        process.queue    = params.slurm_queue ?: 'normal'
    }

    sge {
        process.executor = 'sge'
    }

    test {
        params {
            input           = "${projectDir}/tests/test_samplesheet.csv"
            target_bed      = "${projectDir}/tests/test_targets.bed"
            reference_fasta = "${projectDir}/tests/test_reference.fa"
            bwa_index_dir   = "${projectDir}/tests/bwa_index"
            outdir          = "${projectDir}/tests/results"
        }
        process {
            withLabel: 'process_low'    { cpus = 1; memory = '1.GB'; time = '30.m' }
            withLabel: 'process_medium' { cpus = 2; memory = '4.GB'; time = '1.h'  }
            withLabel: 'process_high'   { cpus = 2; memory = '4.GB'; time = '2.h'  }
        }
    }

    // ── Custom resource profiles ────────────────────────────────────────
    high_depth {
        // For high-depth targeted sequencing (>1000x)
        params {
            mpileup_max_depth          = 50000
            vc_min_depth               = 100
            ff_max_reads               = 50000000
            min_mean_target_coverage   = 1000.0
        }
        process {
            withLabel: 'process_high' {
                cpus   = 16
                memory = '32.GB'
                time   = '12.h'
            }
        }
    }

    low_resource {
        process {
            withLabel: 'process_low'    { cpus = 1; memory = '1.GB'; time = '2.h'  }
            withLabel: 'process_medium' { cpus = 2; memory = '4.GB'; time = '4.h'  }
            withLabel: 'process_high'   { cpus = 4; memory = '8.GB'; time = '8.h'  }
        }
    }
}


// ── Manifest ────────────────────────────────────────────────────────────────
manifest {
    name            = 'single-gene-nipt'
    author          = 'Single Gene NIPT Team'
    homePage        = 'https://github.com/genolyx/sgNIPT'
    description     = 'Non-Invasive Prenatal Testing pipeline for single gene disorder screening'
    mainScript      = 'main.nf'
    nextflowVersion = '!>=23.04.0'
    version         = '1.1.0'
}


// ── Timeline, report, trace ─────────────────────────────────────────────────
timeline {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/timeline.html"
    overwrite = true
}

report {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/report.html"
    overwrite = true
}

trace {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/trace.txt"
    overwrite = true
    fields    = 'task_id,hash,native_id,process,tag,name,status,exit,module,container,cpus,time,disk,memory,attempt,submit,start,complete,duration,realtime,queue,%cpu,%mem,rss,vmem,peak_rss,peak_vmem,rchar,wchar,syscr,syscw,read_bytes,write_bytes,vol_ctxt,inv_ctxt,env'
}

dag {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/dag.html"
    overwrite = true
}
