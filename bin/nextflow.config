/*
 * ============================================================================
 *  Single Gene NIPT Pipeline - Nextflow Configuration
 * ============================================================================
 *
 *  Twist Custom Panel: UCL_SingleGeneNIPT_TE-96276661_hg38
 *  - Target regions: 5,138 regions, ~1.07 Mb, 183 genes, 22 chromosomes
 *  - Probe coverage: 99.46% (777,457 bp covered by probes)
 *  - Zero-probe regions: 29 (3,786 bp) - flagged in QC
 *  - No Y-chromosome targets → ChrX-based supplementary FF for male fetus
 *
 *  Shared Reference Layout (same server as carrier-screening):
 *    /data/reference/
 *      genomes/GRCh38/
 *        GRCh38.fasta, GRCh38.dict, GRCh38.fasta.fai
 *        bwa_index/          ← BWA-MEM index
 *        bwa_mem2_index/     ← BWA-MEM2 index (NEW)
 *      annotation/
 *        vep_cache/          ← Ensembl VEP release 111 cache (shared)
 *        gnomad/             ← gnomAD v3.1.2 genomes (legacy fallback)
 *        clinvar/
 *  Each service symlinks from its own data/refs/ into /data/reference/.
 *  See: src/setup_refs.sh
 * ============================================================================
 */

// ── Pipeline parameters ─────────────────────────────────────────────────────
params {

    // ── Pipeline metadata ───────────────────────────────────────────────
    pipeline_version = '1.2.0'

    // ── Input / Output ──────────────────────────────────────────────────
    input              = null       // Path to FASTQ samplesheet CSV (sample_id,fastq_1,fastq_2)
    input_bam          = null       // Path to BAM samplesheet CSV (sample_id,bam,bai) — skips alignment
    outdir             = './results'

    // ── Reference genome (GRCh38 / hg38) ───────────────────────────────
    //  Shared central reference path: /data/reference/genomes/GRCh38/
    //  Each service symlinks data/refs/ → /data/reference/
    reference_fasta    = '/data/reference/genomes/GRCh38/GRCh38.fasta'
    genome_prefix      = 'GRCh38'

    // ── Aligner: BWA-MEM2 (fixed) ───────────────────────────────────────
    //  ~2× faster than BWA-MEM with identical mapping accuracy.
    //  Index: /data/reference/genomes/GRCh38/bwa_mem2_index/
    //    (contains .bwt.2bit.64, .0123, .pac, .amb, .ann)
    bwa_mem2_index_dir = '/data/reference/genomes/GRCh38/bwa_mem2_index'

    bwa_extra_args          = ''
    samtools_sort_mem       = '768M'  // per-thread sort memory
    min_mapping_quality     = 30
    min_base_quality        = 20
    // true = Picard MarkDuplicates (same algorithm as carrier-screening GATK MarkDuplicates)
    use_picard_markdup      = true

    // ── Target BED files (Twist Custom Panel) ───────────────────────────
    //  target_bed:       All_target_regions_UCL_SingleGeneNIPT_TE-96276661_hg38_*.bed
    //  probes_bed:       Probes_merged_ok_shareable_UCL_SingleGeneNIPT_TE-96276661_hg38_*.bed
    //  ff_snps_bed:      Common SNP list within target regions (MAF > 5%)
    //  zero_probe_bed:   29 regions with no probe coverage
    //  gene_list:        singleGene_NIPT gene list (182 genes)
    target_bed         = null       // [REQUIRED] All target regions BED
    probes_bed         = null       // [RECOMMENDED] Probe footprint BED for capture QC
    ff_snps_bed        = null       // [RECOMMENDED] Common SNP BED for FF estimation
    zero_probe_bed     = null       // [OPTIONAL] Zero-probe regions BED for QC warnings
    gene_list          = null       // [OPTIONAL] Gene list TSV for report annotation

    // ── Preprocessing (fastp) ───────────────────────────────────────────
    fastp_qualified_quality = 15
    fastp_min_length        = 36
    fastp_extra_args        = ''

    // ── Fetal Fraction Estimation ───────────────────────────────────────
    ff_variant_caller       = 'bcftools'   // 'bcftools' or 'freebayes'
    ff_min_alt_fraction     = 0.005
    ff_min_alt_count        = 2
    ff_max_reads            = 10000000
    ff_config               = null
    mpileup_max_depth       = 10000

    // ── Variant Calling: bcftools mpileup + call (fixed) ────────────────
    //  cfDNA NIPT requires detection of fetal variants at VAF ≈ FF/2 (3–10%).
    //  bcftools reports all allele counts without diploid assumptions,
    //  preserving the low-VAF fetal signal that germline callers would filter.
    vc_min_alt_count        = 2
    vc_min_depth            = 50

    // ── VEP Annotation ──────────────────────────────────────────────────
    //  skip_vep = false : Run VEP annotation (RECOMMENDED)
    //    - gnomAD AF, SIFT, PolyPhen, HGVSc/p, MANE, dbSNP written to CSQ
    //    - service-daemon reads CSQ fields → no local gnomAD VCF lookup
    //  skip_vep = true  : Skip VEP (service-daemon falls back to snpEff)
    //
    //  vep_cache_dir: Shared VEP cache (same as carrier-screening).
    //    Setup: see /data/reference/annotation/vep_cache/
    //    Download: docker run ensemblorg/ensembl-vep:release_111 \
    //              perl INSTALL.pl -a cf -s homo_sapiens -y GRCh38 \
    //              -c /data/reference/annotation/vep_cache --CONVERT
    skip_vep        = false
    vep_cache_dir   = '/data/reference/annotation/vep_cache'

    // ClinVar VCF for VEP --custom annotation (bgzipped + tabixed).
    //  Shared path: /data/reference/annotation/clinvar/clinvar.vcf.gz
    //  Download: https://ftp.ncbi.nlm.nih.gov/pub/clinvar/vcf_GRCh38/clinvar.vcf.gz
    //  Then: bgzip -d clinvar.vcf.gz | bgzip > clinvar.vcf.bgz && tabix -p vcf clinvar.vcf.bgz
    clinvar_vcf     = '/data/reference/annotation/clinvar/clinvar.vcf.gz'

    // ── Variant Annotation (legacy snpsift/bcftools — used when skip_vep=true) ──
    run_annotation          = false
    annotation_tool         = 'bcftools'   // 'bcftools' or 'snpsift'
    annotation_db           = null

    // ── Variant Analysis ────────────────────────────────────────────────
    variant_analysis_config = null

    // ── QC Thresholds ───────────────────────────────────────────────────
    fastq_qc_thresholds    = null
    bam_qc_thresholds      = null

    // ── Docker-internal profile ─────────────────────────────────────────
    container_cpus             = null
    container_memory           = null

    // ── Panel-specific QC thresholds (Twist TE-96276661) ────────────────
    min_on_target_rate         = 0.50
    min_mean_target_coverage   = 500.0
    min_probe_coverage_rate    = 0.95
    max_zero_cov_targets       = 50
}


// ── Process resource defaults ───────────────────────────────────────────────
process {
    errorStrategy = 'retry'
    maxRetries    = 2

    withLabel: 'process_low' {
        cpus   = 1
        memory = '2.GB'
        time   = '1.h'
    }
    withLabel: 'process_medium' {
        cpus   = 4
        memory = '8.GB'
        time   = '4.h'
    }
    withLabel: 'process_high' {
        cpus   = 8
        memory = '16.GB'
        time   = '8.h'
    }
}


// ── Execution profiles ──────────────────────────────────────────────────────
profiles {

    standard {
        process.executor = 'local'
    }

    /*
     * docker_internal: Used when Nextflow runs INSIDE a Docker container.
     * All tools are pre-installed in the image; no nested Docker needed.
     *
     * The shared reference tree (/data/reference) must be mounted into the
     * container at the same absolute path so symlinks resolve correctly.
     * See: run_sgnipt.sh  -v /data/reference:/data/reference:ro
     */
    docker_internal {
        process.executor = 'local'
        executor {
            queueSize   = 8
            cpus        = params.container_cpus   ?: 16
            memory      = params.container_memory ?: '32.GB'
        }
    }

    /*
     * docker: Use when launching Nextflow directly on the host (not inside
     * a container). Each process runs in its own Docker container.
     * The shared reference directory is mounted read-only so that symlinks
     * inside data/refs/ resolve to the same absolute path.
     */
    docker {
        docker.enabled    = true
        docker.runOptions = '-u $(id -u):$(id -g) -v /data/reference:/data/reference:ro'
    }

    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
    }

    conda {
        conda.enabled = true
    }

    slurm {
        process.executor = 'slurm'
        process.queue    = params.slurm_queue ?: 'normal'
    }

    sge {
        process.executor = 'sge'
    }

    test {
        params {
            input           = "${projectDir}/tests/test_samplesheet.csv"
            target_bed      = "${projectDir}/tests/test_targets.bed"
            reference_fasta = "${projectDir}/tests/test_reference.fa"
            bwa_mem2_index_dir = "${projectDir}/tests/bwa_mem2_index"
            bwa_index_dir   = "${projectDir}/tests/bwa_index"
            outdir          = "${projectDir}/tests/results"
            skip_vep        = true
        }
        process {
            withLabel: 'process_low'    { cpus = 1; memory = '1.GB'; time = '30.m' }
            withLabel: 'process_medium' { cpus = 2; memory = '4.GB'; time = '1.h'  }
            withLabel: 'process_high'   { cpus = 2; memory = '4.GB'; time = '2.h'  }
        }
    }

    high_depth {
        params {
            mpileup_max_depth          = 50000
            vc_min_depth               = 100
            ff_max_reads               = 50000000
            min_mean_target_coverage   = 1000.0
        }
        process {
            withLabel: 'process_high' {
                cpus   = 16
                memory = '32.GB'
                time   = '12.h'
            }
        }
    }

    low_resource {
        process {
            withLabel: 'process_low'    { cpus = 1; memory = '1.GB'; time = '2.h'  }
            withLabel: 'process_medium' { cpus = 2; memory = '4.GB'; time = '4.h'  }
            withLabel: 'process_high'   { cpus = 4; memory = '8.GB'; time = '8.h'  }
        }
    }
}


// ── Container images ────────────────────────────────────────────────────────
// Used only when running with the 'docker' profile (not docker_internal).
process {
    withName: 'VEP_ANNOTATION' {
        container = 'ensemblorg/ensembl-vep:release_111'
    }
}


// ── Manifest ────────────────────────────────────────────────────────────────
manifest {
    name            = 'single-gene-nipt'
    author          = 'Single Gene NIPT Team'
    homePage        = 'https://github.com/genolyx/sgNIPT'
    description     = 'Non-Invasive Prenatal Testing pipeline for single gene disorder screening'
    mainScript      = 'main.nf'
    nextflowVersion = '!>=23.04.0'
    version         = '1.2.0'
}


// ── Timeline, report, trace ─────────────────────────────────────────────────
timeline {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/timeline.html"
    overwrite = true
}
report {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/report.html"
    overwrite = true
}
trace {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/trace.txt"
    overwrite = true
    fields    = 'task_id,hash,native_id,process,tag,name,status,exit,module,container,cpus,time,disk,memory,attempt,submit,start,complete,duration,realtime,queue,%cpu,%mem,rss,vmem,peak_rss,peak_vmem,rchar,wchar,syscr,syscw,read_bytes,write_bytes,vol_ctxt,inv_ctxt,env'
}
dag {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/dag.html"
    overwrite = true
}
